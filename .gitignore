*.tsbuildinfo
next-env.d.ts

# python (smoke test only)
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# temp files
c.txt
*.log

# AI tool configs (optional - remove if you want to share these)
AGENTS.md
CLAUDE.md
